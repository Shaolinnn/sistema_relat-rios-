# ─────────────────────────────────────────────────────────────
# BrandField Reporting — Environment Variables
# Copy this file to .env and fill in real values for local dev.
# In production (GitHub Actions), set these as repository secrets.
# ─────────────────────────────────────────────────────────────

# ── Meta access tokens (one per client) ──────────────────────
# Variable name must match the `access_token_env` field in the
# corresponding client YAML file.
META_TOKEN_EXAMPLE_CLIENT=your_meta_access_token_here

# ── WhatsApp — Meta Business API ─────────────────────────────
META_WA_TOKEN=your_whatsapp_access_token_here
META_WA_PHONE_ID=your_phone_number_id_here

# ── WhatsApp — Twilio (if using Twilio provider) ─────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WA_FROM=whatsapp:+14155238886

# ── WhatsApp — Evolution API (if using Evolution provider) ────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_INSTANCE=your_instance_name_here
